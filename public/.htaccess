# Forçar Content-Type correto para ads.txt (CRÍTICO para Google AdSense)
<FilesMatch "^ads\.txt$">
  ForceType text/plain
  Header set Content-Type "text/plain; charset=utf-8"
  Header set X-Robots-Tag "noindex"
</FilesMatch>

# Forçar Content-Type para outros arquivos de texto
<FilesMatch "\.(txt|xml)$">
  ForceType text/plain
</FilesMatch>

<FilesMatch "^sitemap\.xml$">
  ForceType application/xml
  Header set Content-Type "application/xml; charset=utf-8"
</FilesMatch>

<FilesMatch "^robots\.txt$">
  ForceType text/plain
  Header set Content-Type "text/plain; charset=utf-8"
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # PRIMEIRO: Servir ads.txt diretamente sem qualquer processamento
  RewriteRule ^ads\.txt$ - [L,T=text/plain]
  
  # Servir robots.txt e sitemap.xml diretamente
  RewriteRule ^robots\.txt$ - [L,T=text/plain]
  RewriteRule ^sitemap\.xml$ - [L,T=application/xml]

  # Não redirecionar arquivos ou diretórios reais
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Proteger arquivos estáticos essenciais de redirecionamento
  RewriteRule ^(favicon\.ico|apple-touch-icon\.png|og-image\.(jpg|png)|\.well-known/|google.+\.html)$ - [L]

  # Redirecionar todas as demais rotas para index.html (SPA)
  RewriteRule ^ index.html [L]
</IfModule>

# Compressão Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache Headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  # Cache curto para ads.txt (permite atualizações rápidas)
  ExpiresByType text/plain "access plus 1 hour"
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
