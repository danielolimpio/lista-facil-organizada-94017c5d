RewriteEngine On
RewriteBase /

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.(env|git|tsx|ts|jsx|js\.map)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Bloquear pastas sensíveis
RewriteRule ^src/ - [F,L]
RewriteRule ^\.git/ - [F,L]

# Servir ads.txt, robots.txt e sitemap.xml diretamente
RewriteRule ^ads\.txt$ - [L,T=text/plain]
RewriteRule ^robots\.txt$ - [L,T=text/plain]
RewriteRule ^sitemap\.xml$ - [L,T=application/xml]

# Servir arquivos estáticos diretamente (CSS, JS, imagens, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Servir diretórios com index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)/?$ $1/index.html [L]

# Redirecionar URLs SEM barra final → COM barra final (exceto arquivos reais)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !\.\w{2,4}$
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ https://helplistas.com.br/$1/ [R=301,L]

# Se ainda não encontrar, tentar servir index.html do diretório
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.*)/?$ $1/index.html [L]

# Forçar Content-Type correto para ads.txt
<FilesMatch "^ads\.txt$">
  ForceType text/plain
  Header set Content-Type "text/plain; charset=utf-8"
</FilesMatch>

<FilesMatch "^sitemap\.xml$">
  ForceType application/xml
  Header set Content-Type "application/xml; charset=utf-8"
</FilesMatch>

<FilesMatch "^robots\.txt$">
  ForceType text/plain
  Header set Content-Type "text/plain; charset=utf-8"
</FilesMatch>

# Compressão Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache Headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/plain "access plus 1 hour"
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
