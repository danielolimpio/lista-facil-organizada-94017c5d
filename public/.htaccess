# ============================================
# CONFIGURAÇÃO PARA SITE 100% ESTÁTICO (SSG)
# Helplistas.com.br - URLs SEM barra final
# ============================================

# Forçar Content-Type correto para ads.txt (CRÍTICO para Google AdSense)
<FilesMatch "^ads\.txt$">
  ForceType text/plain
  Header set Content-Type "text/plain; charset=utf-8"
  Header set X-Robots-Tag "noindex"
</FilesMatch>

# Forçar Content-Type para sitemap.xml
<FilesMatch "^sitemap\.xml$">
  ForceType application/xml
  Header set Content-Type "application/xml; charset=utf-8"
</FilesMatch>

# Forçar Content-Type para robots.txt
<FilesMatch "^robots\.txt$">
  ForceType text/plain
  Header set Content-Type "text/plain; charset=utf-8"
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ============================================
  # 1. FORÇAR HTTPS
  # ============================================
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ============================================
  # 2. SERVIR ARQUIVOS ESTÁTICOS DIRETAMENTE
  # ============================================
  RewriteRule ^ads\.txt$ - [L,T=text/plain]
  RewriteRule ^robots\.txt$ - [L,T=text/plain]
  RewriteRule ^sitemap\.xml$ - [L,T=application/xml]

  # ============================================
  # 3. SERVIR ASSETS DIRETAMENTE (JS, CSS, imagens)
  # ============================================
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # ============================================
  # 4. REMOVER BARRA FINAL (Redirecionar /page/ para /page)
  # Aplica-se inclusive quando existe um diretório com o mesmo nome
  # (ex: /blog/ que possui artigos dentro) — evita 403 do Apache
  # em diretórios sem index.
  # ============================================
  RewriteCond %{REQUEST_URI} !^/$
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^(.+)/$ /$1 [L,R=301]

  # ============================================
  # 5. SERVIR ARQUIVOS .html SEM EXTENSÃO
  # Se a URL é /page, servir /page.html (mesmo se existir
  # um diretório com o mesmo nome, priorizar o .html)
  # ============================================
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ /$1.html [L]

  # ============================================
  # 6. SERVIR SUBPASTAS COM ARQUIVOS .html
  # Se /blog/artigo existe como /blog/artigo.html
  # ============================================
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+)$ /$1.html [L]

  # ============================================
  # 7. FALLBACK PARA SPA (páginas não pré-renderizadas)
  # ============================================
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ /index.html [L]

</IfModule>

# ============================================
# COMPRESSÃO GZIP
# ============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# ============================================
# CACHE HEADERS
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/plain "access plus 1 hour"
</IfModule>

# ============================================
# SECURITY HEADERS
# ============================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
